---
/**
 * Reading Progress Bar Component
 * 阅读进度条组件，显示在页面顶部
 */
---

<div class="reading-progress-bar"></div>

<script>
  // 计算并更新阅读进度
  function updateReadingProgress() {
    const progressBar = document.querySelector('.reading-progress-bar') as HTMLElement;
    if (!progressBar) return;

    // 计算滚动进度
    const windowHeight = window.innerHeight;
    const documentHeight = document.documentElement.scrollHeight;
    const scrollTop = window.pageYOffset || document.documentElement.scrollTop;

    // 计算百分比
    const scrollPercent = (scrollTop / (documentHeight - windowHeight)) * 100;

    // 更新进度条宽度
    progressBar.style.width = `${Math.min(scrollPercent, 100)}%`;
  }

  // 初始化
  function initReadingProgress() {
    // 初始更新
    updateReadingProgress();

    // 监听滚动事件
    window.addEventListener('scroll', updateReadingProgress, { passive: true });

    // 监听窗口大小变化
    window.addEventListener('resize', updateReadingProgress, { passive: true });
  }

  // 页面加载完成后初始化
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initReadingProgress);
  } else {
    initReadingProgress();
  }
</script>

<style>
  .reading-progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    width: 0%;
    background: linear-gradient(to right, var(--color-primary), var(--color-primary-hover));
    z-index: 9999;
    transition: width 0.1s ease-out;
  }

  /* 护眼模式 */
  :global(body.sepia) .reading-progress-bar {
    background: linear-gradient(to right, #704214, #8b5319);
  }

  /* 夜间模式 */
  :global(body.night) .reading-progress-bar {
    background: linear-gradient(to right, #bdcadb, #8d9bb3);
  }
</style>
