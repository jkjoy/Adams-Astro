---
/**
 * Social Component
 * 显示在 Header 右上角的社交链接
 */
import { siteConfig } from '../site.config';

const { social } = siteConfig;
const links = social.links.filter(link => link.url); // 只显示配置了 URL 的链接
---

{links.length > 0 && (
  <nav class="social" aria-label="社交链接">
    <ul>
      {links.map(link => (
        <li>
          <a
            href={link.url}
            aria-label={link.name}
            target={link.url.startsWith('http') ? '_blank' : undefined}
            rel={link.url.startsWith('http') ? 'noopener noreferrer' : undefined}
          >
            <i class={link.icon} aria-hidden="true"></i>
            <span class="sr-only">{link.name}</span>
          </a>
          {link.qrcode && (
            <img src={link.qrcode} alt={`${link.name} 二维码`} />
          )}
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  /* Social 样式已在 global.css 中定义 */

  /* Screen reader only - 隐藏但对屏幕阅读器可见 */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
