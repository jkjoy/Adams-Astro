---
import { siteConfig } from '../site.config';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  // 文章信息（仅文章页传入）
  postTitle?: string;
  postDate?: Date;
  postSlug?: string;
  // 页码（用于分页）
  pageNumber?: number;
}

const { title, description, image, postTitle, postDate, postSlug, pageNumber } = Astro.props;

const { site, seo } = siteConfig;
const currentPath = Astro.url.pathname;
const isHomePage = currentPath === '/';

// 用于 SEO 的 title
// 如果有 pageNumber，在标题后面添加页码
let pageTitle = title ? `${title} - ${site.title}` : site.title;
if (pageNumber && pageNumber > 1) {
  pageTitle = `${site.title} - 第 ${pageNumber} 页`;
}
const pageDescription = description || site.description;
const pageImage = new URL(image || seo.ogImage, site.url).toString();
const pageUrl = new URL(currentPath, site.url).toString();
const ogType = postTitle ? 'article' : 'website';

// 用于 Header h1 显示的标题
// 首页和分页显示网站名称，其他页面显示页面标题（文章标题或页面标题）
const headerTitle = isHomePage || pageNumber ? site.name : (postTitle || title || site.name);
---

<!DOCTYPE html>
<html lang={site.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="author" content={site.author} />
    <link rel="canonical" href={pageUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={pageImage} />
    <meta property="og:url" content={pageUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content={seo.twitterCard} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={pageImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- 内联关键 CSS - 优化首屏渲染 -->
    <style is:inline>
      :root{--color-primary:#3274ff;--color-text-primary:#434a54;--color-text-secondary:#656D78;--color-bg-primary:#FFF;--color-bg-secondary:#F5F7FA;--color-border-light:#E6E9ED;--font-family-base:"lucida grande","lucida sans unicode",lucida,helvetica,"PingFang SC","Hiragino Sans GB","STHeiti Light","Microsoft YaHei","WenQuanYi Micro Hei",sans-serif;--container-max-width:780px;--container-padding:2%;--transition-fast:0.3s}html.sepia,body.sepia{--color-primary:#704214;--color-text-primary:#704214;--color-bg-primary:#f3eacb;--color-bg-secondary:#eae0be;--color-border-light:#eae0be}html.night,body.night{--color-primary:#bdcadb;--color-text-primary:#bdcadb;--color-text-secondary:#666e8e;--color-bg-primary:#1c1f2b;--color-bg-secondary:#393f56;--color-border-light:#393f56}*{box-sizing:border-box}html,body{margin:0;padding:0}body{font-family:var(--font-family-base);font-size:1rem;line-height:1.5;color:var(--color-text-primary);background:var(--color-bg-primary);-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}.container{max-width:var(--container-max-width);margin:0 auto;padding:0 var(--container-padding)}.header{background:var(--color-bg-primary);border-bottom:1px solid var(--color-border-light)}a{color:var(--color-text-primary);text-decoration:none}img{max-width:100%;height:auto}@font-face{font-family:'StrawberryIcon-pro';src:url('/fonts/StrawberryIcon-pro.woff?cgglgw') format('woff');font-weight:normal;font-style:normal;font-display:swap}[class^="czs-"],[class*=" czs-"]{font-family:'StrawberryIcon-pro'!important;font-style:normal;font-weight:normal;display:inline-block;line-height:1}
    </style>

    <!-- 预加载图标字体 -->
    <link
      rel="preload"
      href="/fonts/StrawberryIcon-pro.woff?cgglgw"
      as="font"
      type="font/woff"
      crossorigin
    />

    <!-- 防止主题闪烁 - 在页面渲染前应用主题 -->
    <script is:inline>
      // 立即执行，在页面渲染前应用主题
      (function() {
        const colorTheme = localStorage.getItem('adams_color_style');
        const fontTheme = localStorage.getItem('adams_font_style');

        if (colorTheme) {
          document.documentElement.classList.add(colorTheme);
        }
        if (fontTheme) {
          document.documentElement.classList.add(fontTheme);
        }
      })();
    </script>
  </head>
  <body>
    <Header
      headerTitle={headerTitle}
      postTitle={postTitle}
      postDate={postDate}
      postSlug={postSlug}
    />
    <main class="main-load">
      <div class="container">
        <slot />
      </div>
    </main>
    <Footer />
    <ThemeSwitcher />
  </body>
</html>
