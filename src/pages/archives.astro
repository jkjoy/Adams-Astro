---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// 获取所有已发布的文章
const allPosts = await getCollection('posts', ({ data }) => {
  return data.draft !== true;
});

// 按日期排序
const sortedPosts = allPosts.sort((a, b) => {
  return b.data.date.valueOf() - a.data.date.valueOf();
});

// 按年份和月份分组
interface PostsByYear {
  [year: string]: {
    [month: string]: typeof allPosts;
  };
}

const postsByYear: PostsByYear = {};

sortedPosts.forEach((post) => {
  const date = post.data.date;
  const year = date.getFullYear().toString();
  const month = (date.getMonth() + 1).toString().padStart(2, '0');

  if (!postsByYear[year]) {
    postsByYear[year] = {};
  }
  if (!postsByYear[year][month]) {
    postsByYear[year][month] = [];
  }
  postsByYear[year][month].push(post);
});

// 获取所有年份并排序
const years = Object.keys(postsByYear).sort((a, b) => Number(b) - Number(a));

// 月份名称映射
const monthNames: { [key: string]: string } = {
  '01': '一月',
  '02': '二月',
  '03': '三月',
  '04': '四月',
  '05': '五月',
  '06': '六月',
  '07': '七月',
  '08': '八月',
  '09': '九月',
  '10': '十月',
  '11': '十一月',
  '12': '十二月',
};

// 格式化日期
function formatDate(date: Date) {
  return date.toLocaleDateString('zh-CN', {
    month: 'long',
    day: 'numeric'
  });
}
---

<BaseLayout title="文章归档" description="按时间归档的所有文章">
  <div class="archives">

    {years.map((year) => (
      <section class="year-section">
        <h2 class="year-title">{year}</h2>

        {Object.keys(postsByYear[year])
          .sort((a, b) => Number(b) - Number(a))
          .map((month) => (
            <div class="month-group">
              <h3 class="month-title">{monthNames[month]}</h3>
              <ul class="post-list">
                {postsByYear[year][month].map((post) => (
                  <li class="post-item">
                    <time datetime={post.data.date.toISOString()}>
                      {formatDate(post.data.date)}
                    </time>
                    <a href={`/posts/${post.slug}`}>{post.data.title}</a>
                    {post.data.tags && post.data.tags.length > 0 && (
                      <span class="tags-inline">
                        {post.data.tags.map((tag) => (
                          <a href={`/tags/${tag}`} class="tag">{tag}</a>
                        ))}
                      </span>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          ))}
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  .archives {
    max-width: 100%;
  }

  .archive-header {
    text-align: center;
    margin: 0 0 4rem;
    padding: 2rem 0;
    border-bottom: 2px solid var(--color-border-light);
  }

  .archive-header h1 {
    font-size: 2rem;
    font-weight: bold;
    color: var(--color-text-primary);
    margin: 0 0 0.5rem;
  }

  .archive-header p {
    font-size: 1rem;
    color: var(--color-text-tertiary);
  }

  .year-section {
    margin: 0 0 3rem;
  }

  .year-title {
    font-size: 1.8rem;
    font-weight: bold;
    color: var(--color-text-primary);
    margin: 0 0 1.5rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border-light);
  }

  .month-group {
    margin: 0 0 2rem;
  }

  .month-title {
    font-size: 1.2rem;
    font-weight: bold;
    color: var(--color-text-secondary);
    margin: 0 0 1rem;
    padding-left: 1rem;
    border-left: 3px solid var(--color-primary);
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-item {
    padding: 0.5rem 0;
    display: flex;
    align-items: baseline;
    gap: 1rem;
    line-height: 2rem;
    border-bottom: 1px dashed var(--color-border-light);
  }

  .post-item:last-child {
    border-bottom: none;
  }

  .post-item time {
    font-size: 0.9rem;
    color: var(--color-text-tertiary);
    min-width: 80px;
    flex-shrink: 0;
  }

  .post-item a {
    color: var(--color-text-secondary);
    text-decoration: none;
    flex: 1;
  }

  .post-item a:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .tags-inline {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .tag {
    font-size: 0.75rem;
    padding: 2px 8px;
    border-radius: 10px;
    background: rgba(136, 136, 136, 0.1);
    color: var(--color-text-tertiary);
    text-decoration: none;
    white-space: nowrap;
  }

  .tag:hover {
    background: var(--color-primary);
    color: white;
  }

  @media (max-width: 42rem) {
    .post-item {
      flex-direction: column;
      gap: 0.25rem;
      align-items: flex-start;
    }

    .post-item time {
      font-size: 0.8rem;
      min-width: auto;
    }

    .tags-inline {
      margin-top: 0.25rem;
    }
  }
</style>
